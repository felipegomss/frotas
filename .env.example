DATABASE_URL="postgresql://frotas:frotas@localhost:5432/frotas?schema=admin"
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="frotas-dev"
AWS_ENDPOINT="http://localhost:4566"
# Phase-1 dev-only: enables spoofable header-based tenant resolution
# (X-Tenant-Schema). Leave UNSET in any shared/production environment — without
# it, tenant routes reject requests (403). Phase 2 derives the tenant from auth.
ALLOW_HEADER_TENANT="1"
