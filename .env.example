DATABASE_URL="postgresql://frotas:frotas@localhost:5432/frotas?schema=admin"
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="frotas-dev"
AWS_ENDPOINT="http://localhost:4566"

# Auth (M0-F01, ADR 0010).
# IdP verification (Cognito in prod; local fake OIDC issuer in dev/test).
IDP_ISSUER="https://cognito-idp.sa-east-1.amazonaws.com/POOL_ID"
IDP_AUDIENCE="frotas-api"
IDP_JWKS_URL="https://cognito-idp.sa-east-1.amazonaws.com/POOL_ID/.well-known/jwks.json"
# Secret that signs the API session token carrying the active tenant claim.
SESSION_TOKEN_SECRET="dev-only-change-me"
SESSION_TOKEN_TTL="1h"
