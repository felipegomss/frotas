{
  "name": "@frotas/db", "version": "0.0.0", "private": true, "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.json",
    "seed": "node dist/seed.js",
    "migrate:admin": "prisma migrate dev",
    "template:build": "prisma migrate diff --from-empty --to-schema-datamodel prisma/tenant.prisma --script > prisma/tenant-template.sql"
  },
  "dependencies": { "@prisma/client": "latest", "@prisma/adapter-pg": "latest", "pg": "latest" },
  "devDependencies": { "prisma": "latest", "typescript": "latest", "@types/pg": "latest" }
}
