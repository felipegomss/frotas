// Control plane (admin). Fixed, managed by Prisma.
// Tenant schemas are created outside Prisma (runner + tenant-template.sql).
// Prisma 7 is Rust-free: the client needs a driver adapter (PrismaPg) at runtime.
// The datasource url does NOT live here — it is provided by prisma.config.ts.
generator client {
  provider            = "prisma-client"
  output              = "../src/generated/client"
  runtime             = "nodejs"
  moduleFormat        = "esm"
  importFileExtension = "js"
}
datasource db {
  provider = "postgresql"
}

model Identity {
  id String @id @default(uuid())
  cpf String @unique
  email String @unique
  name String
  authSub String? @map("auth_sub")
  status String @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  memberships Membership[]
  @@map("identities")
}
model Tenant {
  id String @id @default(uuid())
  slug String @unique
  schemaName String @unique @map("schema_name")
  name String
  status String @default("provisioning")
  createdAt DateTime @default(now()) @map("created_at")
  memberships Membership[]
  invites Invite[]
  @@map("tenants")
}
model Membership {
  id String @id @default(uuid())
  identityId String @map("identity_id")
  tenantId String @map("tenant_id")
  role String
  status String @default("active")
  identity Identity @relation(fields: [identityId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
  @@unique([identityId, tenantId, role])
  @@map("memberships")
}
model Invite {
  id String @id @default(uuid())
  tenantId String @map("tenant_id")
  email String
  role String
  token String @unique
  expiresAt DateTime @map("expires_at")
  usedAt DateTime? @map("used_at")
  tenant Tenant @relation(fields: [tenantId], references: [id])
  @@map("invites")
}
model ProvisioningJob {
  id String @id @default(uuid())
  tenantId String @map("tenant_id")
  status String @default("pending")
  error String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("provisioning_jobs")
}
